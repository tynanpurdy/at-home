{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/components": ["./src/components"],
      "@/ui": ["./src/components/ui"],
      "@/lib": ["./src/lib"],
      "@/utils": ["./src/lib/utils"],
      "@/hooks": ["./src/hooks"],
      "@/styles": ["./src/styles"]
    }
  },
  "exclude": ["dist", "src/pages/enhanced-showcase.astro"]
}
