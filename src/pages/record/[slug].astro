---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordUI from "../../components/ui/record"; // Using the new enhanced Record component
import { Button } from "../../components/ui/button"; // For action buttons
import { Separator } from "../../components/ui/separator"; // For styling
import { createATProtoClient } from "../../lib/atproto";
import { getATProtoConfig } from "../../config/atproto";
import { getLexiconForRecord } from "../../lib/lexicons";
import { ChevronRight, ArrowLeft, Share2 } from "lucide-react"; // For icons

export async function getStaticPaths() {
    const config = getATProtoConfig();
    const atClient = createATProtoClient(config);

    try {
        // Get all records that support full page view
        const { recentActivity } = await atClient.getActivityData({
            includeBlogPosts: true,
            includeRepositoryStats: false,
            activityLimit: 100, // Get more records to find full-page capable ones
            blogPostLimit: 50,
            collectionsLimit: 10,
        });

        const paths = [];

        // Add blog posts and other full-page records
        recentActivity.forEach((record) => {
            const lexicon = getLexiconForRecord(record);
            if (lexicon && lexicon.supportedViews.includes("full")) {
                const rkey = record.uri.split("/").pop();
                paths.push({
                    params: { slug: rkey },
                    props: { record }, // Profile is now handled by BaseLayout
                });
            }
        });

        return paths;
    } catch (error) {
        console.error("Error generating record paths:", error);
        return [];
    }
}

const { slug } = Astro.params;
const { record } = Astro.props;

if (!record) {
    return Astro.redirect("/404");
}

const lexicon = getLexiconForRecord(record);
if (!lexicon || !lexicon.supportedViews.includes("full")) {
    return Astro.redirect("/404");
}

const title = lexicon.getTitle(record);
const author = lexicon.getAuthor(record);
const description = `${lexicon.name} by ${author.name}`;
---

<BaseLayout
    title={`${title} - ${author.name}`}
    description={description}
    currentPage="activity"
>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Breadcrumb -->
        <nav class="mb-8" aria-label="Breadcrumb">
            <ol
                class="flex items-center space-x-2 text-sm text-muted-foreground"
            >
                <li>
                    <a href="/" class="hover:text-foreground">Home</a>
                </li>
                <li class="flex items-center">
                    <ChevronRight class="w-3 h-3 mx-2 text-muted-foreground" />
                    <a href="/activity" class="hover:text-foreground"
                        >Activity</a
                    >
                </li>
                <li class="flex items-center">
                    <ChevronRight class="w-3 h-3 mx-2 text-muted-foreground" />
                    <span class="font-medium text-foreground"
                        >{lexicon.name}</span
                    >
                </li>
            </ol>
        </nav>

        <!-- Record Content -->
        <RecordUI client:load record={record} view="full" showAuthor={true} />

        <!-- Related Actions -->
        <div class="mt-8 pt-8 border-t border-border">
            <div
                class="flex flex-col sm:flex-row items-center justify-between gap-4"
            >
                <div class="flex items-center gap-2">
                    <Button variant="outline" size="sm" asChild>
                        <a href="/activity">
                            <ArrowLeft class="w-4 h-4 mr-2" />
                            Back to Activity
                        </a>
                    </Button>
                    {
                        lexicon.collection === "com.whtwnd.blog.entry" && (
                            <Button variant="outline" size="sm" asChild>
                                <a href="/blog">View All Blog Posts</a>
                            </Button>
                        )
                    }
                </div>

                <!-- Share button (optional) -->
                <Button
                    variant="ghost"
                    size="sm"
                    class="text-muted-foreground hover:text-foreground"
                    onclick="navigator.share ? navigator.share({title: document.title, url: window.location.href}) : navigator.clipboard.writeText(window.location.href)"
                    title="Share this record"
                    client:load
                >
                    <Share2 class="w-4 h-4 mr-2" />
                    Share
                </Button>
            </div>
        </div>
    </div>
</BaseLayout>
