---
import { getLexiconForRecord } from "../../lib/lexicons";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Record from "../../components/Record.tsx";
import {
    getCachedProfile,
    getCachedActivity,
    getCachedBlogPosts,
} from "../../data/cache-utils";
import { getDataWithFallback } from "../../data/cache-fallback";

export async function getStaticPaths() {
    try {
        // First try to use cached data
        let profile = getCachedProfile();
        let recentActivity = getCachedActivity();
        let blogPosts = getCachedBlogPosts();

        // If cache is invalid or empty, fall back to direct fetch
        if (!profile || recentActivity.length === 0) {
            console.log("Cache invalid or empty, falling back to direct fetch");
            const freshData = await getDataWithFallback();
            profile = freshData.profile;
            recentActivity = freshData.recentActivity;
            blogPosts = freshData.blogPosts;
        }

        // Combine activity and blog posts to ensure we catch all full-page capable records
        const allRecords = [...recentActivity, ...blogPosts];

        const paths = [];

        // Add blog posts and other full-page records
        allRecords.forEach((record) => {
            const lexicon = getLexiconForRecord(record);
            if (lexicon && lexicon.supportedViews.includes("full")) {
                const rkey = record.uri.split("/").pop();
                paths.push({
                    params: { slug: rkey },
                    props: { record, profile },
                });
            }
        });

        return paths;
    } catch (error) {
        console.error("Error generating record paths:", error);
        return [];
    }
}

const { slug } = Astro.params;
const { record, profile } = Astro.props;

if (!record) {
    return Astro.redirect("/404");
}

const lexicon = getLexiconForRecord(record);
if (!lexicon || !lexicon.supportedViews.includes("full")) {
    return Astro.redirect("/404");
}

const title = lexicon.getTitle(record);
const author = lexicon.getAuthor(record);
---

<BaseLayout
    title={`${title} - ${profile?.displayName || profile?.handle || "AT Home"}`}
    description={`${lexicon.name} by ${author.name}`}
    profile={profile}
>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Breadcrumb -->
        <nav class="mb-8" aria-label="Breadcrumb">
            <ol
                class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400"
            >
                <li>
                    <a
                        href="/"
                        class="hover:text-gray-700 dark:hover:text-gray-300"
                        >Home</a
                    >
                </li>
                <li class="flex items-center">
                    <span class="mx-2">/</span>
                    <a
                        href="/activity"
                        class="hover:text-gray-700 dark:hover:text-gray-300"
                        >Activity</a
                    >
                </li>
                <li class="flex items-center">
                    <span class="mx-2">/</span>
                    <span class="text-gray-900 dark:text-white font-medium"
                        >{lexicon.name}</span
                    >
                </li>
            </ol>
        </nav>

        <!-- Record Content -->
        <Record record={record} view="full" showAuthor={true} />

        <!-- Related Actions -->
        <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <a
                        href="/activity"
                        class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium"
                    >
                        ← Back to Activity
                    </a>
                    {
                        lexicon.collection === "com.whtwnd.blog.entry" && (
                            <a
                                href="/blog"
                                class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium"
                            >
                                View All Blog Posts
                            </a>
                        )
                    }
                </div>

                <!-- Share button (optional) -->
                <button
                    onclick="navigator.share ? navigator.share({title: document.title, url: window.location.href}) : navigator.clipboard.writeText(window.location.href)"
                    class="text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 text-sm"
                    title="Share this record"
                >
                    Share
                </button>
            </div>
        </div>
    </div>
</BaseLayout>
