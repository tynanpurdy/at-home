---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createATProtoClient } from "../lib/atproto";
import { getATProtoConfig } from "../config/atproto";
import BlogPost from "../components/ui/blog-post";
import ActivityFeed from "../components/ui/activity-feed";
import ProfileCard from "../components/ui/profile-card";
import {
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
} from "../components/ui/card";
import { Badge } from "../components/ui/badge";
import { Button } from "../components/ui/button";
import { Separator } from "../components/ui/separator";

// Get AT Protocol configuration
const config = getATProtoConfig();

// Initialize AT Protocol client
const atClient = createATProtoClient(config);

// Fetch data at build time using unified approach
const { profile, recentActivity, blogPosts } = await atClient.getActivityData({
    includeBlogPosts: true,
    includeRepositoryStats: false,
    activityLimit: 8,
    blogPostLimit: 3,
    collectionsLimit: 5,
});
---

<BaseLayout
    title={`${profile?.displayName || profile?.handle || "AT Home"} - Personal Portfolio & Blog`}
    description="Personal portfolio and blog powered by the AT Protocol"
    currentPage="home"
    profile={profile}
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Hero Section -->
        <section class="mb-12">
            <div class="text-center">
                <h1 class="text-4xl font-bold text-foreground mb-4">
                    Welcome to My Digital Home
                </h1>
                <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
                    This is my personal portfolio and blog, powered by the AT
                    Protocol. Here you'll find my thoughts, projects, and
                    activity across the decentralized web.
                </p>
            </div>
        </section>

        <!-- Grid Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Content Area -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Latest Blog Posts -->
                <Card>
                    <CardHeader>
                        <div class="flex items-center justify-between">
                            <CardTitle class="text-2xl"
                                >Latest Blog Posts</CardTitle
                            >
                            <Button variant="ghost" asChild>
                                <a href="/blog"> View all posts → </a>
                            </Button>
                        </div>
                    </CardHeader>
                    <CardContent>
                        {
                            blogPosts.length > 0 ? (
                                <div class="space-y-6">
                                    {blogPosts.map((post) => (
                                        <BlogPost
                                            key={post.uri}
                                            client:load
                                            post={post}
                                            variant="compact"
                                        />
                                    ))}
                                </div>
                            ) : (
                                <div class="text-center py-8">
                                    <div class="text-6xl mb-4">📝</div>
                                    <h3 class="text-xl font-medium text-foreground mb-2">
                                        No blog posts found yet
                                    </h3>
                                    <p class="text-muted-foreground">
                                        Posts will appear here when you publish
                                        them using the WhiteWind lexicon.
                                    </p>
                                </div>
                            )
                        }
                    </CardContent>
                </Card>

                <!-- Recent Activity -->
                <ActivityFeed
                    client:load
                    records={recentActivity}
                    title="Recent Activity"
                    maxItems={5}
                    variant="default"
                    showViewAll={true}
                    viewAllHref="/activity"
                    emptyMessage="No recent activity found."
                    emptySubMessage="Activity from your AT Protocol repository will appear here."
                />
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <!-- Profile Card -->
                {
                    profile && (
                        <div>
                            <h2 class="text-xl font-bold text-foreground mb-4">
                                About Me
                            </h2>
                            <ProfileCard
                                client:load
                                profile={profile}
                                variant="compact"
                            />
                        </div>
                    )
                }

                <!-- AT Protocol Info -->
                <Card>
                    <CardHeader>
                        <CardTitle class="text-lg"
                            >Powered by AT Protocol</CardTitle
                        >
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground mb-4">
                            This site is built on the AT Protocol, a
                            decentralized social networking protocol. All
                            content is fetched directly from my AT Protocol
                            repository.
                        </p>
                        <div class="space-y-2">
                            <div
                                class="flex items-center justify-between text-sm"
                            >
                                <span class="text-muted-foreground"
                                    >Blog Posts:</span
                                >
                                <Badge variant="secondary">WhiteWind</Badge>
                            </div>
                            <div
                                class="flex items-center justify-between text-sm"
                            >
                                <span class="text-muted-foreground"
                                    >Social:</span
                                >
                                <Badge variant="secondary">Bluesky</Badge>
                            </div>
                            <div
                                class="flex items-center justify-between text-sm"
                            >
                                <span class="text-muted-foreground"
                                    >Protocol:</span
                                >
                                <Badge variant="secondary">AT Protocol</Badge>
                            </div>
                        </div>
                        <Separator class="my-4" />
                        <Button variant="outline" size="sm" asChild>
                            <a
                                href="https://atproto.com"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                Learn more about AT Protocol →
                            </a>
                        </Button>
                    </CardContent>
                </Card>

                <!-- Quick Links -->
                <Card>
                    <CardHeader>
                        <CardTitle class="text-lg">Quick Links</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-2">
                            <Button
                                variant="ghost"
                                class="w-full justify-start p-0 h-auto"
                                asChild
                            >
                                <a href="/blog" class="block p-2 text-sm">
                                    📝 All Blog Posts
                                </a>
                            </Button>
                            <Button
                                variant="ghost"
                                class="w-full justify-start p-0 h-auto"
                                asChild
                            >
                                <a href="/activity" class="block p-2 text-sm">
                                    🔄 Recent Activity
                                </a>
                            </Button>
                            <Button
                                variant="ghost"
                                class="w-full justify-start p-0 h-auto"
                                asChild
                            >
                                <a href="/about" class="block p-2 text-sm">
                                    👤 About Me
                                </a>
                            </Button>
                            {
                                profile && (
                                    <Button
                                        variant="ghost"
                                        class="w-full justify-start p-0 h-auto"
                                        asChild
                                    >
                                        <a
                                            href={`https://bsky.app/profile/${profile.handle}`}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="block p-2 text-sm"
                                        >
                                            🐦 Follow on Bluesky
                                        </a>
                                    </Button>
                                )
                            }
                        </div>
                    </CardContent>
                </Card>

                <!-- Component Showcase -->
                <Card>
                    <CardHeader>
                        <CardTitle class="text-lg"
                            >Enhanced Components</CardTitle
                        >
                        <CardDescription
                            >Now powered by shadcn/ui</CardDescription
                        >
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-3">
                            <div class="text-sm">
                                <div class="flex items-center justify-between">
                                    <span class="text-muted-foreground"
                                        >Design System:</span
                                    >
                                    <Badge variant="outline">shadcn/ui</Badge>
                                </div>
                            </div>
                            <div class="text-sm">
                                <div class="flex items-center justify-between">
                                    <span class="text-muted-foreground"
                                        >Accessibility:</span
                                    >
                                    <Badge variant="outline">Enhanced</Badge>
                                </div>
                            </div>
                            <div class="text-sm">
                                <div class="flex items-center justify-between">
                                    <span class="text-muted-foreground"
                                        >Theme Support:</span
                                    >
                                    <Badge variant="outline">Dark/Light</Badge>
                                </div>
                            </div>
                        </div>
                        <Separator class="my-4" />
                        <Button variant="outline" size="sm" asChild>
                            <a href="/enhanced-showcase">
                                View Component Showcase →
                            </a>
                        </Button>
                    </CardContent>
                </Card>
            </div>
        </div>
    </div>
</BaseLayout>
