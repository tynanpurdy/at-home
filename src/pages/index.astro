---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/ui/blog-post";
import ActivityFeed from "../components/ui/activity-feed";
import ProfileCard from "../components/ui/profile-card";
import {
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
} from "../components/ui/card";
import { Badge } from "../components/ui/badge";
import { Button } from "../components/ui/button";
import { Separator } from "../components/ui/separator";
import {
    getCachedProfile,
    getLimitedActivity,
    getLimitedBlogPosts,
    isCacheValid,
} from "../data/cache-utils";

// Load data from cache
const profile = getCachedProfile();
const recentActivity = getLimitedActivity(8);
const blogPosts = getLimitedBlogPosts(3);

// Check if cache is valid (this can be used for debugging or fallback strategies)
const cacheValid = isCacheValid();
---

<BaseLayout
    title={`${profile?.displayName || profile?.handle || "AT Home"} - Personal Portfolio & Blog`}
    description="Personal portfolio and blog powered by the AT Protocol"
    currentPage="home"
    profile={profile}
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Hero Section -->
        <section class="mb-12">
            <div class="text-center">
                <h1 class="text-4xl font-bold text-foreground mb-4">
                    Welcome to My Digital Home
                </h1>
                <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
                    This is my personal portfolio and blog, powered by the AT
                    Protocol. Here you'll find my thoughts, projects, and
                    activity across the decentralized web.
                </p>
            </div>
        </section>

        <!-- Grid Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Content Area -->
            <div class="lg:col-span-2 grid grid-cols-1 gap-8">
                <!-- Latest Blog Posts -->
                <CardHeader>
                    <div class="flex justify-between">
                        <CardTitle>Latest Blog Posts</CardTitle>
                        <Button variant="ghost" asChild>
                            <a href="/blog"> View all posts → </a>
                        </Button>
                    </div>
                </CardHeader>
                <CardContent>
                    {
                        blogPosts.length > 0 ? (
                            <div class="grid grid-cols-1 gap-4">
                                {blogPosts.map((post) => (
                                    <BlogPost
                                        client:load
                                        post={post}
                                        variant="compact"
                                    />
                                ))}
                            </div>
                        ) : (
                            <div class="text-center py-8">
                                <div class="text-6xl mb-4">📝</div>
                                <h3 class="text-xl font-medium text-foreground mb-2">
                                    No blog posts found yet
                                </h3>
                                <p class="text-muted-foreground">
                                    Posts will appear here when you publish them
                                    using the WhiteWind lexicon.
                                </p>
                            </div>
                        )
                    }
                </CardContent>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6 grid grid-cols-1 gap-8">
                <!-- Profile Card -->
                {
                    profile && (
                        <div>
                            <h2 class="text-xl font-bold text-foreground">
                                About Me
                            </h2>
                            <ProfileCard
                                client:load
                                profile={profile}
                                variant="compact"
                            />
                        </div>
                    )
                }

                <!-- Recent Activity -->
                <ActivityFeed
                    client:load
                    records={recentActivity}
                    title="Recent Activity"
                    maxItems={5}
                    variant="default"
                    showViewAll={true}
                    viewAllHref="/activity"
                    emptyMessage="No recent activity found."
                    emptySubMessage="Activity from your AT Protocol repository will appear here."
                />

                <!-- AT Protocol Info -->
                <Card>
                    <CardHeader>
                        <CardTitle>Powered by AT Protocol</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground">
                            This site is built on the AT Protocol, a
                            decentralized social networking protocol. All
                            content is fetched directly from my AT Protocol
                            repository.
                        </p>
                        <div class="space-y-2">
                            <div
                                class="flex items-center justify-between text-sm"
                            >
                                <span class="text-muted-foreground"
                                    >Blog Posts:</span
                                >
                                <Badge variant="secondary">WhiteWind</Badge>
                            </div>
                            <div
                                class="flex items-center justify-between text-sm"
                            >
                                <span class="text-muted-foreground"
                                    >Social:</span
                                >
                                <Badge variant="secondary">Bluesky</Badge>
                            </div>
                            <div
                                class="flex items-center justify-between text-sm"
                            >
                                <span class="text-muted-foreground"
                                    >Protocol:</span
                                >
                                <Badge variant="secondary">AT Protocol</Badge>
                            </div>
                        </div>
                        <Separator />
                        <Button variant="outline" size="sm" asChild>
                            <a
                                href="https://atproto.com"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                Learn more about AT Protocol →
                            </a>
                        </Button>
                    </CardContent>
                </Card>
            </div>
        </div>
    </div>
</BaseLayout>
