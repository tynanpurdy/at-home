---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileCard from "../components/ui/profile-card";
import {
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
} from "../components/ui/card";
import { Badge } from "../components/ui/badge";
import { Separator } from "../components/ui/separator";
import { Button } from "../components/ui/button";
import { getCachedProfile } from "../data/cache-utils";
import {
    LayoutDashboard,
    Atom,
    Palette,
    Globe,
    Feather,
    Share2,
    CheckCircle,
    Server,
    Github,
    Link,
    Code,
    MessageCircleMore,
} from "lucide-react";

// Load profile data from cache
const profile = getCachedProfile();
---

<BaseLayout
    title={`About - ${profile?.displayName || profile?.handle || "AT Home"}`}
    description="Learn more about me and this AT Protocol-powered website"
    currentPage="about"
    profile={profile}
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-4xl font-bold text-foreground mb-4">About Me</h1>
            <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
                Learn more about me and this decentralized website powered by
                the AT Protocol
            </p>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Content -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Profile Section -->
                {
                    profile && (
                        <Card>
                            <CardHeader>
                                <CardTitle class="flex items-center gap-2">
                                    <LayoutDashboard className="w-5 h-5" />
                                    My Profile
                                </CardTitle>
                                <CardDescription>
                                    My digital identity on the AT Protocol.
                                </CardDescription>
                            </CardHeader>
                            <CardContent>
                                <ProfileCard
                                    client:load
                                    profile={profile}
                                    compact={false}
                                />
                            </CardContent>
                        </Card>
                    )
                }

                <!-- About This Site -->
                <Card>
                    <CardHeader>
                        <CardTitle class="flex items-center gap-2">
                            <Share2 className="w-5 h-5" />
                            About This Site
                        </CardTitle>
                        <CardDescription>
                            Welcome to my personal corner of the decentralized
                            web!
                        </CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div
                            class="prose prose-lg max-w-none dark:prose-invert"
                        >
                            <p class="text-muted-foreground mb-4">
                                This website is built with{" "}
                                <a
                                    href="https://astro.build"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-primary hover:underline"
                                >
                                    Astro
                                </a>{" "}
                                and powered by the{" "}
                                <a
                                    href="https://atproto.com"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-primary hover:underline"
                                >
                                    AT Protocol
                                </a>
                                , representing a new approach to personal websites
                                and digital identity.
                            </p>

                            <p class="text-muted-foreground mb-4">
                                Instead of relying on traditional databases or
                                content management systems, all content on this
                                site is fetched directly from my AT Protocol
                                repository. This means I truly own my data, and
                                it's stored in a decentralized, interoperable
                                format that can be accessed by any compatible
                                application.
                            </p>

                            <p class="text-muted-foreground mb-4">
                                Blog posts are published using the{" "}
                                <a
                                    href="https://whitewind.app"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-primary hover:underline"
                                >
                                    WhiteWind
                                </a>{" "}
                                lexicon, which allows for rich, long-form content
                                that's still part of the AT Protocol ecosystem. This
                                creates a seamless bridge between traditional blogging
                                and the decentralized social web.
                            </p>
                        </div>
                    </CardContent>
                </Card>

                <!-- Tech Stack -->
                <Card>
                    <CardHeader>
                        <CardTitle class="flex items-center gap-2">
                            <Code className="w-5 h-5" />
                            Tech Stack
                        </CardTitle>
                        <CardDescription>
                            The technologies that power this website.
                        </CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-4">
                                <h3
                                    class="text-lg font-semibold text-foreground"
                                >
                                    Frontend
                                </h3>
                                <div class="space-y-2">
                                    <div class="flex items-center space-x-3">
                                        <Badge
                                            variant="secondary"
                                            className="p-2"
                                        >
                                            <LayoutDashboard
                                                className="w-6 h-6 text-primary"
                                            />
                                        </Badge>
                                        <div>
                                            <p
                                                class="font-medium text-foreground"
                                            >
                                                Astro
                                            </p>
                                            <p
                                                class="text-sm text-muted-foreground"
                                            >
                                                Static site generator
                                            </p>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-3">
                                        <Badge
                                            variant="secondary"
                                            className="p-2"
                                        >
                                            <Atom
                                                className="w-6 h-6 text-primary"
                                            />
                                        </Badge>
                                        <div>
                                            <p
                                                class="font-medium text-foreground"
                                            >
                                                React
                                            </p>
                                            <p
                                                class="text-sm text-muted-foreground"
                                            >
                                                Interactive components
                                            </p>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-3">
                                        <Badge
                                            variant="secondary"
                                            className="p-2"
                                        >
                                            <Palette
                                                className="w-6 h-6 text-primary"
                                            />
                                        </Badge>
                                        <div>
                                            <p
                                                class="font-medium text-foreground"
                                            >
                                                Tailwind CSS
                                            </p>
                                            <p
                                                class="text-sm text-muted-foreground"
                                            >
                                                Utility-first styling
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="space-y-4">
                                <h3
                                    class="text-lg font-semibold text-foreground"
                                >
                                    Backend/Data
                                </h3>
                                <div class="space-y-2">
                                    <div class="flex items-center space-x-3">
                                        <Badge
                                            variant="secondary"
                                            className="p-2"
                                        >
                                            <Globe
                                                className="w-6 h-6 text-primary"
                                            />
                                        </Badge>
                                        <div>
                                            <p
                                                class="font-medium text-foreground"
                                            >
                                                AT Protocol
                                            </p>
                                            <p
                                                class="text-sm text-muted-foreground"
                                            >
                                                Decentralized data layer
                                            </p>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-3">
                                        <Badge
                                            variant="secondary"
                                            className="p-2"
                                        >
                                            <Feather
                                                className="w-6 h-6 text-primary"
                                            />
                                        </Badge>
                                        <div>
                                            <p
                                                class="font-medium text-foreground"
                                            >
                                                WhiteWind
                                            </p>
                                            <p
                                                class="text-sm text-muted-foreground"
                                            >
                                                Blogging lexicon
                                            </p>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-3">
                                        <Badge
                                            variant="secondary"
                                            className="p-2"
                                        >
                                            <MessageCircleMore
                                                className="w-6 h-6 text-primary"
                                            />
                                        </Badge>
                                        <div>
                                            <p
                                                class="font-medium text-foreground"
                                            >
                                                Bluesky
                                            </p>
                                            <p
                                                class="text-sm text-muted-foreground"
                                            >
                                                Social platform
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </CardContent>
                </Card>

                <!-- Features -->
                <Card>
                    <CardHeader>
                        <CardTitle class="flex items-center gap-2">
                            <CheckCircle className="w-5 h-5" />
                            Key Features
                        </CardTitle>
                        <CardDescription>
                            Highlights of this AT Protocol-powered website.
                        </CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-3">
                                <div class="flex items-start space-x-3">
                                    <Badge variant="secondary" className="p-2">
                                        <CheckCircle
                                            className="w-5 h-5 text-green-600"
                                        />
                                    </Badge>
                                    <div>
                                        <p class="font-medium text-foreground">
                                            Decentralized Content
                                        </p>
                                        <p
                                            class="text-sm text-muted-foreground"
                                        >
                                            All content fetched from AT Protocol
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-start space-x-3">
                                    <Badge variant="secondary" className="p-2">
                                        <CheckCircle
                                            className="w-5 h-5 text-green-600"
                                        />
                                    </Badge>
                                    <div>
                                        <p class="font-medium text-foreground">
                                            Real-time Updates
                                        </p>
                                        <p
                                            class="text-sm text-muted-foreground"
                                        >
                                            Content syncs with your AT Protocol
                                            repo
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-start space-x-3">
                                    <Badge variant="secondary" className="p-2">
                                        <CheckCircle
                                            className="w-5 h-5 text-green-600"
                                        />
                                    </Badge>
                                    <div>
                                        <p class="font-medium text-foreground">
                                            Cross-platform
                                        </p>
                                        <p
                                            class="text-sm text-muted-foreground"
                                        >
                                            Works with any AT Protocol client
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="space-y-3">
                                <div class="flex items-start space-x-3">
                                    <Badge variant="secondary" className="p-2">
                                        <CheckCircle
                                            className="w-5 h-5 text-green-600"
                                        />
                                    </Badge>
                                    <div>
                                        <p class="font-medium text-foreground">
                                            Own Your Data
                                        </p>
                                        <p
                                            class="text-sm text-muted-foreground"
                                        >
                                            No vendor lock-in, portable content
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-start space-x-3">
                                    <Badge variant="secondary" className="p-2">
                                        <CheckCircle
                                            className="w-5 h-5 text-green-600"
                                        />
                                    </Badge>
                                    <div>
                                        <p class="font-medium text-foreground">
                                            Dark Mode
                                        </p>
                                        <p
                                            class="text-sm text-muted-foreground"
                                        >
                                            Respects system preferences
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-start space-x-3">
                                    <Badge variant="secondary" className="p-2">
                                        <CheckCircle
                                            className="w-5 h-5 text-green-600"
                                        />
                                    </Badge>
                                    <div>
                                        <p class="font-medium text-foreground">
                                            Responsive Design
                                        </p>
                                        <p
                                            class="text-sm text-muted-foreground"
                                        >
                                            Works on all devices
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </CardContent>
                </Card>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <!-- Contact/Links -->
                <Card>
                    <CardHeader>
                        <CardTitle class="flex items-center gap-2">
                            <Link className="w-5 h-5" />
                            Connect
                        </CardTitle>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-3">
                            {
                                profile && (
                                    <Button
                                        variant="ghost"
                                        class="w-full justify-start p-0 h-auto"
                                        asChild
                                    >
                                        <a
                                            href={`https://bsky.app/profile/${profile.handle}`}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="flex items-center space-x-3 p-3 rounded-lg hover:bg-accent transition-colors"
                                        >
                                            <Badge
                                                variant="secondary"
                                                className="p-2"
                                            >
                                                <MessageCircleMore className="w-6 h-6 text-primary" />
                                            </Badge>
                                            <div>
                                                <p class="font-medium text-foreground">
                                                    Bluesky
                                                </p>
                                                <p class="text-sm text-muted-foreground">
                                                    @{profile.handle}
                                                </p>
                                            </div>
                                        </a>
                                    </Button>
                                )
                            }
                            <Button
                                variant="ghost"
                                class="w-full justify-start p-0 h-auto"
                                asChild
                            >
                                <a
                                    href="https://github.com"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center space-x-3 p-3 rounded-lg hover:bg-accent transition-colors"
                                >
                                    <Badge variant="secondary" className="p-2">
                                        <Github
                                            className="w-6 h-6 text-primary"
                                        />
                                    </Badge>
                                    <div>
                                        <p class="font-medium text-foreground">
                                            GitHub
                                        </p>
                                        <p
                                            class="text-sm text-muted-foreground"
                                        >
                                            View source code
                                        </p>
                                    </div>
                                </a>
                            </Button>
                            <Button
                                variant="ghost"
                                class="w-full justify-start p-0 h-auto"
                                asChild
                            >
                                <a
                                    href="https://atproto.com"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center space-x-3 p-3 rounded-lg hover:bg-accent transition-colors"
                                >
                                    <Badge variant="secondary" className="p-2">
                                        <Globe
                                            className="w-6 h-6 text-primary"
                                        />
                                    </Badge>
                                    <div>
                                        <p class="font-medium text-foreground">
                                            AT Protocol
                                        </p>
                                        <p
                                            class="text-sm text-muted-foreground"
                                        >
                                            Learn more
                                        </p>
                                    </div>
                                </a>
                            </Button>
                        </div>
                    </CardContent>
                </Card>

                <!-- Site Stats -->
                <Card>
                    <CardHeader>
                        <CardTitle class="flex items-center gap-2">
                            <Server className="w-5 h-5" />
                            Site Info
                        </CardTitle>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between">
                                <span class="text-muted-foreground"
                                    >Built with:</span
                                >
                                <Badge variant="outline">Astro</Badge>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-muted-foreground"
                                    >Data source:</span
                                >
                                <Badge variant="outline">AT Protocol</Badge>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-muted-foreground"
                                    >Blog platform:</span
                                >
                                <Badge variant="outline">WhiteWind</Badge>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-muted-foreground"
                                    >Hosting:</span
                                >
                                <Badge variant="outline">Static</Badge>
                            </div>
                        </div>
                    </CardContent>
                </Card>

                <!-- Philosophy -->
                <Card>
                    <CardHeader>
                        <CardTitle class="flex items-center gap-2">
                            <MessageCircleMore className="w-5 h-5" />
                            Philosophy
                        </CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground">
                            I believe in the importance of owning your digital
                            identity and content. This site represents a step
                            toward a more decentralized, user-controlled
                            internet where your data truly belongs to you.
                        </p>
                    </CardContent>
                </Card>
            </div>
        </div>
    </div>
</BaseLayout>
