---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createATProtoClient } from "../lib/atproto";
import { getATProtoConfig } from "../config/atproto";
import {
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
} from "../components/ui/card";
import { Badge } from "../components/ui/badge";
import { Separator } from "../components/ui/separator";
import { Button } from "../components/ui/button";
import {
    Settings,
    User,
    List,
    ScrollText,
    FlaskConical,
    AlertTriangle,
    CheckCircle,
    XCircle,
    ExternalLink,
    Code,
} from "lucide-react";

interface ATProtoProfile {
    did: string;
    handle: string;
    displayName?: string;
    description?: string;
    avatar?: string;
    banner?: string;
    followersCount: number;
    followsCount: number;
    postsCount: number;
    indexedAt: string;
    labels: any[];
}

interface WhiteWindPost {
    uri: string;
    cid: string;
    author: any;
    record: {
        title: string;
        content: string;
        tags?: string[];
        createdAt: string;
    };
}

interface SampleRecord {
    uri: string;
    createdAt: string;
    valueKeys: string[];
    hasText: boolean;
    hasSubject: boolean;
    hasReason: boolean;
    textContent: string | null;
    subject: any | null;
    reason: any | null;
    fullValue: any;
}

interface SampleRecords {
    [key: string]: {
        count: number;
        records: SampleRecord[];
    };
}

interface ErrorInfo {
    collection?: string;
    general?: boolean;
    error: string;
    status?: any;
    details?: any;
}

interface DebugData {
    config: {
        service: string;
        identifier: string;
        handle: string;
        hasPassword: boolean;
    };
    profile: ATProtoProfile | null;
    collections: string[];
    whiteWindPosts: WhiteWindPost[];
    sampleRecords: SampleRecords;
    errors: ErrorInfo[];
}

// Get AT Protocol configuration
const config = getATProtoConfig();

// Initialize AT Protocol client
const atClient = createATProtoClient(config);

// Test data
let debugData: DebugData = {
    config: {
        service: config.service,
        identifier: config.identifier,
        handle: config.handle,
        hasPassword: !!config.password,
    },
    profile: null,
    collections: [],
    whiteWindPosts: [],
    sampleRecords: {},
    errors: [],
};

try {
    console.log("🧪 Starting AT Protocol debug test...");

    // Test profile fetch
    console.log("👤 Testing profile fetch...");
    debugData.profile = await atClient.getProfile();
    console.log("✅ Profile fetched:", debugData.profile.handle);

    // Test collections discovery
    console.log("📚 Testing collections discovery...");
    const collectionsResponse =
        await atClient.agent.api.com.atproto.repo.describeRepo({
            repo: debugData.profile.did,
        });
    debugData.collections = collectionsResponse.data.collections.map(
        (c) => c.name,
    ); // Ensure we get just the names
    console.log("✅ Collections found:", debugData.collections.length);

    // Test WhiteWind posts
    console.log("📝 Testing WhiteWind posts...");
    debugData.whiteWindPosts = await atClient.getWhiteWindPosts(undefined, 5);
    console.log("✅ WhiteWind posts found:", debugData.whiteWindPosts.length);

    // Test each collection individually
    console.log("🔍 Testing individual collections...");
    const collectionsToTest = [
        "app.bsky.feed.post",
        "app.bsky.feed.like",
        "app.bsky.feed.repost",
        "app.bsky.graph.follow",
        "com.whtwnd.blog.entry", // Include blog entry for specific testing
        "app.bsky.actor.profile", // Include profile updates
    ];

    for (const collection of collectionsToTest) {
        try {
            console.log(`📂 Testing collection: ${collection}`);
            const records = await atClient.getRepositoryRecords(
                collection,
                undefined,
                3,
            );
            console.log(`   Records found: ${records.length}`);

            debugData.sampleRecords[collection] = {
                count: records.length,
                records: records.map((record) => ({
                    uri: record.uri,
                    createdAt: record.value.createdAt,
                    valueKeys: Object.keys(record.value),
                    hasText: "text" in record.value,
                    hasSubject: "subject" in record.value,
                    hasReason: "reason" in record.value,
                    textContent: record.value.text
                        ? String(record.value.text).substring(0, 100)
                        : null,
                    subject: record.value.subject || null,
                    reason: record.value.reason || null,
                    fullValue: record.value,
                })),
            };
        } catch (error) {
            console.log(
                `❌ Error with ${collection}:`,
                (error as Error).message,
            );
            debugData.errors.push({
                collection,
                error: (error as Error).message,
                // @ts-ignore
                status: error.status, // Assuming error might have a status property
            });
        }
    }

    console.log("🎉 Debug test completed successfully!");
} catch (error) {
    console.error("❌ Debug test failed:", error);
    debugData.errors.push({
        general: true,
        error: (error as Error).message,
        // @ts-ignore
        status: (error as any).status,
        details: error,
    });
}
---

<BaseLayout
    title={`AT Protocol Debug - ${debugData.profile?.handle || "Debug"}`}
    description="Debugging your AT Protocol connection and data"
    currentPage="debug"
>
    <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="text-center mb-8">
            <h1 className="text-4xl font-bold text-foreground mb-4">
                AT Protocol Debug
            </h1>
            <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
                Debugging your AT Protocol connection and data
            </p>
            <Button variant="link" asChild className="mt-4">
                <a href="/">← Back to Home</a>
            </Button>
        </div>

        <!-- Configuration -->
        <Card>
            <CardHeader>
                <CardTitle className="flex items-center gap-2">
                    <Settings className="w-5 h-5" /> Configuration
                </CardTitle>
                <CardDescription>
                    Your AT Protocol client configuration.
                </CardDescription>
            </CardHeader>
            <CardContent>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                    <div class="flex items-center justify-between">
                        <span class="text-muted-foreground">Service:</span>
                        <Badge variant="outline">
                            {debugData.config.service}
                        </Badge>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-muted-foreground">Identifier:</span>
                        <Badge variant="outline">
                            {debugData.config.identifier}
                        </Badge>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-muted-foreground">Handle:</span>
                        <Badge variant="outline">
                            {debugData.config.handle}
                        </Badge>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-muted-foreground">Has Password:</span>
                        <Badge
                            variant={debugData.config.hasPassword
                                ? "secondary"
                                : "destructive"}
                        >
                            {debugData.config.hasPassword ? "✅ Yes" : "❌ No"}
                        </Badge>
                    </div>
                </div>
            </CardContent>
        </Card>

        <!-- Profile -->
        {
            debugData.profile && (
                <Card>
                    <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                            <User className="w-5 h-5" /> Profile
                        </CardTitle>
                        <CardDescription>
                            Your fetched AT Protocol profile data.
                        </CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                            <div class="flex items-center justify-between">
                                <span class="text-muted-foreground">
                                    Handle:
                                </span>
                                <Badge variant="outline">
                                    {debugData.profile.handle}
                                </Badge>
                            </div>
                            <div class="flex items-center justify-between">
                                <span className="text-muted-foreground">
                                    Display Name:
                                </span>
                                <Badge variant="outline">
                                    {debugData.profile.displayName}
                                </Badge>
                            </div>
                            <div class="col-span-1 md:col-span-2 flex items-center justify-between">
                                <span className="text-muted-foreground">
                                    DID:
                                </span>
                                <Badge variant="outline">
                                    {debugData.profile.did}
                                </Badge>
                            </div>
                            <div class="flex items-center justify-between">
                                <span className="text-muted-foreground">
                                    Followers:
                                </span>
                                <Badge variant="secondary">
                                    {debugData.profile.followersCount}
                                </Badge>
                            </div>
                            <div class="flex items-center justify-between">
                                <span className="text-muted-foreground">
                                    Following:
                                </span>
                                <Badge variant="secondary">
                                    {debugData.profile.followsCount}
                                </Badge>
                            </div>
                            <div class="flex items-center justify-between">
                                <span className="text-muted-foreground">
                                    Posts:
                                </span>
                                <Badge variant="secondary">
                                    {debugData.profile.postsCount}
                                </Badge>
                            </div>
                        </div>
                    </CardContent>
                </Card>
            )
        }

        <!-- Collections -->
        <Card>
            <CardHeader>
                <CardTitle className="flex items-center gap-2">
                    <List className="w-5 h-5" /> Available Collections
                </CardTitle>
                <CardDescription>
                    Collections discovered in your AT Protocol repository.
                </CardDescription>
            </CardHeader>
            <CardContent>
                <div class="space-y-2 text-sm">
                    {
                        debugData.collections.map((collection) => (
                            <div class="flex items-center justify-between p-2 bg-muted rounded">
                                <Badge variant="outline">{collection}</Badge>
                                {debugData.sampleRecords[collection] && (
                                    <Badge variant="secondary">
                                        {
                                            debugData.sampleRecords[collection]
                                                .count
                                        }{" "}
                                        records
                                    </Badge>
                                )}
                            </div>
                        ))
                    }
                </div>
            </CardContent>
        </Card>

        <!-- WhiteWind Posts -->
        <Card>
            <CardHeader>
                <CardTitle className="flex items-center gap-2">
                    <ScrollText className="w-5 h-5" /> WhiteWind Posts
                </CardTitle>
                <CardDescription>
                    Sample of blog posts fetched using WhiteWind lexicon.
                </CardDescription>
            </CardHeader>
            <CardContent>
                <p class="text-sm text-muted-foreground mb-4">
                    Found {debugData.whiteWindPosts.length} WhiteWind blog posts
                </p>
                {
                    debugData.whiteWindPosts.length > 0 && (
                        <div class="space-y-4">
                            {debugData.whiteWindPosts.map((post) => (
                                <div class="border border-border rounded p-4">
                                    <h3 class="font-medium text-foreground">
                                        {post.record.title}
                                    </h3>
                                    <p class="text-sm text-muted-foreground mt-1">
                                        {post.record.createdAt} •{" "}
                                        {post.record.content?.length || 0}{" "}
                                        characters
                                    </p>
                                    {post.record.tags &&
                                        post.record.tags.length > 0 && (
                                            <div class="mt-2 flex flex-wrap gap-1">
                                                {post.record.tags.map((tag) => (
                                                    <Badge
                                                        key={tag}
                                                        variant="secondary"
                                                    >
                                                        #{tag}
                                                    </Badge>
                                                ))}
                                            </div>
                                        )}
                                    <Button
                                        variant="link"
                                        size="sm"
                                        asChild
                                        className="mt-2"
                                    >
                                        <a
                                            href={`https://whtwnd.com/${post.author.handle}/${post.uri.split("/").pop()}`}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                        >
                                            View on WhiteWind{" "}
                                            <ExternalLink className="w-3 h-3 ml-1" />
                                        </a>
                                    </Button>
                                </div>
                            ))}
                        </div>
                    )
                }
            </CardContent>
        </Card>

        <!-- Sample Records -->
        <div class="space-y-6">
            {
                Object.entries(debugData.sampleRecords).map(
                    ([collection, data]) => (
                        <Card key={collection}>
                            <CardHeader>
                                <CardTitle className="flex items-center gap-2">
                                    <FlaskConical className="w-5 h-5" />{" "}
                                    {collection} ({data.count} records)
                                </CardTitle>
                            </CardHeader>
                            <CardContent>
                                {data.records.length > 0 ? (
                                    <div class="space-y-4">
                                        {data.records.map((record, index) => (
                                            <div
                                                key={index}
                                                class="border border-border rounded p-4"
                                            >
                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm mb-4">
                                                    <div class="flex items-center justify-between">
                                                        <span class="text-muted-foreground">
                                                            URI:
                                                        </span>{" "}
                                                        <Badge variant="outline">
                                                            {record.uri}
                                                        </Badge>
                                                    </div>
                                                    <div class="flex items-center justify-between">
                                                        <span class="text-muted-foreground">
                                                            Created:
                                                        </span>{" "}
                                                        <Badge variant="outline">
                                                            {record.createdAt}
                                                        </Badge>
                                                    </div>
                                                    <div class="flex items-center justify-between">
                                                        <span className="text-muted-foreground">
                                                            Has Text:
                                                        </span>{" "}
                                                        <Badge
                                                            variant={
                                                                record.hasText
                                                                    ? "secondary"
                                                                    : "destructive"
                                                            }
                                                        >
                                                            {record.hasText
                                                                ? "✅"
                                                                : "❌"}
                                                        </Badge>
                                                    </div>
                                                    <div class="flex items-center justify-between">
                                                        <span className="text-muted-foreground">
                                                            Has Subject:
                                                        </span>{" "}
                                                        <Badge
                                                            variant={
                                                                record.hasSubject
                                                                    ? "secondary"
                                                                    : "destructive"
                                                            }
                                                        >
                                                            {record.hasSubject
                                                                ? "✅"
                                                                : "❌"}
                                                        </Badge>
                                                    </div>
                                                    {record.hasReason && (
                                                        <div class="flex items-center justify-between">
                                                            <span className="text-muted-foreground">
                                                                Has Reason:
                                                            </span>{" "}
                                                            <Badge variant="secondary">
                                                                ✅
                                                            </Badge>
                                                        </div>
                                                    )}
                                                </div>

                                                {record.textContent && (
                                                    <p class="text-sm text-muted-foreground mb-2">
                                                        <strong>Text:</strong> "
                                                        {record.textContent}..."
                                                    </p>
                                                )}

                                                {record.subject && (
                                                    <p class="text-sm text-muted-foreground mb-2">
                                                        <strong>
                                                            Subject:
                                                        </strong>{" "}
                                                        <code className="bg-muted px-1 rounded text-foreground text-xs">
                                                            {JSON.stringify(
                                                                record.subject,
                                                            )}
                                                        </code>
                                                    </p>
                                                )}

                                                {record.reason && (
                                                    <p class="text-sm text-muted-foreground mb-2">
                                                        <strong>Reason:</strong>{" "}
                                                        <code class="bg-muted px-1 rounded text-foreground text-xs">
                                                            {JSON.stringify(
                                                                record.reason,
                                                            )}
                                                        </code>
                                                    </p>
                                                )}
                                                <Separator className="my-4" />
                                                <details className="text-sm text-muted-foreground">
                                                    <summary className="cursor-pointer hover:text-foreground">
                                                        Show Full Record Value
                                                    </summary>
                                                    <pre className="mt-2 text-xs bg-muted p-2 rounded overflow-x-auto text-foreground">
                                                        <code>
                                                            {JSON.stringify(
                                                                record.fullValue,
                                                                null,
                                                                2,
                                                            )}
                                                        </code>
                                                    </pre>
                                                </details>
                                            </div>
                                        ))}
                                    </div>
                                ) : (
                                    <p class="text-muted-foreground text-sm">
                                        No sample records found for this
                                        collection.
                                    </p>
                                )}
                            </CardContent>
                        </Card>
                    ),
                )
            }
        </div>

        <!-- Errors -->
        {
            debugData.errors.length > 0 && (
                <Card class="bg-destructive/10 border-destructive text-destructive-foreground p-6 mt-6">
                    <CardHeader>
                        <CardTitle class="flex items-center gap-2 text-destructive">
                            <AlertTriangle className="w-5 h-5" /> Errors
                        </CardTitle>
                        <CardDescription class="text-destructive-foreground/80">
                            Issues encountered during AT Protocol debugging.
                        </CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-3">
                            {debugData.errors.map((error, index) => (
                                <div
                                    key={index}
                                    class="text-sm text-destructive-foreground"
                                >
                                    <strong>
                                        {error.collection || "General"}:
                                    </strong>{" "}
                                    {error.error}
                                    {error.status && (
                                        <Badge
                                            variant="destructive"
                                            class="ml-2"
                                        >
                                            Status: {error.status}
                                        </Badge>
                                    )}
                                    {error.details && (
                                        <details class="mt-2">
                                            <summary class="cursor-pointer text-destructive-foreground/80 hover:text-destructive-foreground">
                                                Show Details
                                            </summary>
                                            <pre class="mt-2 text-xs bg-destructive/20 p-2 rounded overflow-x-auto text-destructive-foreground">
                                                <code>
                                                    {JSON.stringify(
                                                        error.details,
                                                        null,
                                                        2,
                                                    )}
                                                </code>
                                            </pre>
                                        </details>
                                    )}
                                </div>
                            ))}
                        </div>
                    </CardContent>
                </Card>
            )
        }
    </div>
</BaseLayout>
