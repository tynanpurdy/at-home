---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileCard from "../components/ui/profile-card";
import ActivityFeed from "../components/ui/activity-feed";
import BlogPost from "../components/ui/blog-post";
import Record from "../components/ui/record";
import RecordList from "../components/ui/record-list";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "../components/ui/card";
import { Badge } from "../components/ui/badge";
import { Button } from "../components/ui/button";
import { Separator } from "../components/ui/separator";
import { createATProtoClient } from '../lib/atproto';
import { getATProtoConfig } from '../config/atproto';

// Get AT Protocol configuration
const config = getATProtoConfig();

// Initialize AT Protocol client
const atClient = createATProtoClient(config);

// Fetch data at build time
const { profile, recentActivity, blogPosts } = await atClient.getActivityData({
  includeBlogPosts: true,
  includeRepositoryStats: false,
  activityLimit: 10,
  blogPostLimit: 3,
  collectionsLimit: 5,
});
---

<BaseLayout title="Enhanced Components Showcase" description="Comprehensive showcase of all enhanced shadcn/ui components">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold mb-4">Enhanced Components Showcase</h1>
      <p class="text-muted-foreground text-lg">
        A comprehensive showcase of all enhanced components built with shadcn/ui
      </p>
    </div>

    <!-- Migration Status -->
    <Card class="mb-8">
      <CardHeader>
        <CardTitle>Migration Status</CardTitle>
        <CardDescription>Progress on transitioning from custom components to shadcn/ui</CardDescription>
      </CardHeader>
      <CardContent>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="text-center">
            <div class="text-3xl font-bold text-green-600">5</div>
            <div class="text-sm text-muted-foreground">Components Enhanced</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-blue-600">3</div>
            <div class="text-sm text-muted-foreground">Pages Ready</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-purple-600">100%</div>
            <div class="text-sm text-muted-foreground">Functionality Preserved</div>
          </div>
        </div>
      </CardContent>
    </Card>

    <div class="grid gap-8">
      <!-- ProfileCard Component -->
      <Card>
        <CardHeader>
          <CardTitle>ProfileCard Component</CardTitle>
          <CardDescription>Enhanced profile display with multiple variants</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-6">
            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Default</Badge>
                Full Profile Card
              </h3>
              {profile && (
                <ProfileCard client:load profile={profile} />
              )}
            </div>

            <Separator />

            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Compact</Badge>
                Compact Profile Card
              </h3>
              {profile && (
                <ProfileCard client:load profile={profile} variant="compact" />
              )}
            </div>

            <Separator />

            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Minimal</Badge>
                Profile Card without Actions
              </h3>
              {profile && (
                <ProfileCard client:load profile={profile} showActions={false} />
              )}
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- BlogPost Component -->
      <Card>
        <CardHeader>
          <CardTitle>BlogPost Component</CardTitle>
          <CardDescription>Enhanced blog post display with improved typography and interactions</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-6">
            {blogPosts.length > 0 ? (
              <>
                <div>
                  <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                    <Badge variant="outline">Default</Badge>
                    Full Blog Post
                  </h3>
                  <BlogPost client:load post={blogPosts[0]} />
                </div>

                <Separator />

                <div>
                  <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                    <Badge variant="outline">Compact</Badge>
                    Compact Blog Post
                  </h3>
                  <BlogPost client:load post={blogPosts[0]} variant="compact" />
                </div>

                <Separator />

                <div>
                  <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                    <Badge variant="outline">Minimal</Badge>
                    Blog Post without External Link
                  </h3>
                  <BlogPost client:load post={blogPosts[0]} showExternalLink={false} />
                </div>
              </>
            ) : (
              <div class="text-center py-8 text-muted-foreground">
                <p>No blog posts available to showcase</p>
                <p class="text-sm">Blog posts will appear here when you publish them using WhiteWind</p>
              </div>
            )}
          </div>
        </CardContent>
      </Card>

      <!-- Record Component -->
      <Card>
        <CardHeader>
          <CardTitle>Record Component</CardTitle>
          <CardDescription>Enhanced AT Protocol record display with improved visual hierarchy</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-6">
            {recentActivity.length > 0 ? (
              <>
                <div>
                  <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                    <Badge variant="outline">Compact</Badge>
                    Compact Record View
                  </h3>
                  <Record client:load record={recentActivity[0]} view="compact" />
                </div>

                <Separator />

                <div>
                  <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                    <Badge variant="outline">Expanded</Badge>
                    Expanded Record View
                  </h3>
                  <Record client:load record={recentActivity[0]} view="expanded" />
                </div>

                <Separator />

                <div>
                  <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                    <Badge variant="outline">Full</Badge>
                    Full Record View
                  </h3>
                  <Record client:load record={recentActivity[0]} view="full" />
                </div>
              </>
            ) : (
              <div class="text-center py-8 text-muted-foreground">
                <p>No activity records available to showcase</p>
                <p class="text-sm">Activity records will appear here when you have AT Protocol activity</p>
              </div>
            )}
          </div>
        </CardContent>
      </Card>

      <!-- RecordList Component -->
      <Card>
        <CardHeader>
          <CardTitle>RecordList Component</CardTitle>
          <CardDescription>Enhanced record list with filtering and pagination</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-6">
            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Default</Badge>
                Full Record List
              </h3>
              <RecordList
                client:load
                records={recentActivity}
                title="Recent Activity"
                maxItems={3}
                showViewAll={true}
                viewAllHref="/activity"
              />
            </div>

            <Separator />

            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Compact</Badge>
                Compact Record List
              </h3>
              <RecordList
                client:load
                records={recentActivity}
                view="compact"
                title="Recent Activity (Compact)"
                maxItems={5}
              />
            </div>

            <Separator />

            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Filtered</Badge>
                Filtered Record List (Posts Only)
              </h3>
              <RecordList
                client:load
                records={recentActivity}
                title="Recent Posts"
                maxItems={3}
                filterLexicons={["app.bsky.feed.post"]}
              />
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- ActivityFeed Component -->
      <Card>
        <CardHeader>
          <CardTitle>ActivityFeed Component</CardTitle>
          <CardDescription>Enhanced activity feed with icons and better visual hierarchy</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-6">
            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Default</Badge>
                Full Activity Feed
              </h3>
              <ActivityFeed
                client:load
                records={recentActivity}
                maxItems={5}
                showViewAll={true}
                viewAllHref="/activity"
              />
            </div>

            <Separator />

            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Compact</Badge>
                Compact Activity Feed
              </h3>
              <ActivityFeed
                client:load
                records={recentActivity}
                variant="compact"
                maxItems={3}
                title="Recent Activity (Compact)"
              />
            </div>

            <Separator />

            <div>
              <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
                <Badge variant="outline">Empty</Badge>
                Empty Activity Feed
              </h3>
              <ActivityFeed
                client:load
                records={[]}
                title="Empty Feed Example"
                emptyMessage="No activity yet"
                emptySubMessage="This is how the feed looks when empty."
              />
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- Feature Comparison -->
      <Card>
        <CardHeader>
          <CardTitle>Enhancement Features</CardTitle>
          <CardDescription>Key improvements in the enhanced components</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h3 class="text-lg font-semibold mb-4 text-green-600">✅ Improvements</h3>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start gap-2">
                  <span class="text-green-600">•</span>
                  <span>Consistent design system with shadcn/ui</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600">•</span>
                  <span>Better accessibility with ARIA attributes</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600">•</span>
                  <span>Theme-aware colors and dark mode support</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600">•</span>
                  <span>Improved typography and spacing</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600">•</span>
                  <span>Enhanced mobile responsiveness</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600">•</span>
                  <span>Better hover and focus states</span>
                </li>
              </ul>
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-4 text-blue-600">🚀 New Features</h3>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start gap-2">
                  <span class="text-blue-600">•</span>
                  <span>Activity icons and visual hierarchy</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600">•</span>
                  <span>Enhanced empty states with guidance</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600">•</span>
                  <span>Improved loading and error states</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600">•</span>
                  <span>Better time formatting and display</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600">•</span>
                  <span>More flexible layout options</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600">•</span>
                  <span>Enhanced component composition</span>
                </li>
              </ul>
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- Usage Examples -->
      <Card>
        <CardHeader>
          <CardTitle>Usage Examples</CardTitle>
          <CardDescription>Code examples for using the enhanced components</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="space-y-6">
            <div>
              <h4 class="font-semibold mb-2">ProfileCard Component:</h4>
              <pre class="bg-muted p-4 rounded-lg text-sm overflow-x-auto"><code>{`<ProfileCard
  profile={profile}
  variant="compact"
  showStats={true}
  showActions={false}
  className="mb-4"
/>`}</code></pre>
            </div>

            <div>
              <h4 class="font-semibold mb-2">BlogPost Component:</h4>
              <pre class="bg-muted p-4 rounded-lg text-sm overflow-x-auto"><code>{`<BlogPost
  post={blogPost}
  variant="default"
  showAuthor={true}
  showExternalLink={true}
/>`}</code></pre>
            </div>

            <div>
              <h4 class="font-semibold mb-2">ActivityFeed Component:</h4>
              <pre class="bg-muted p-4 rounded-lg text-sm overflow-x-auto"><code>{`<ActivityFeed
  records={recentActivity}
  maxItems={5}
  variant="default"
  showViewAll={true}
  viewAllHref="/activity"
/>`}</code></pre>
            </div>

            <div>
              <h4 class="font-semibold mb-2">RecordList Component:</h4>
              <pre class="bg-muted p-4 rounded-lg text-sm overflow-x-auto"><code>{`<RecordList
  records={records}
  view="expanded"
  title="Recent Posts"
  maxItems={10}
  filterLexicons={["app.bsky.feed.post"]}
  showViewAll={true}
/>`}</code></pre>
            </div>
          </div>
        </CardContent>
      </Card>

      <!-- Next Steps -->
      <Card>
        <CardHeader>
          <CardTitle>Next Steps</CardTitle>
          <CardDescription>Ready to integrate these enhanced components into your pages</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid md:grid-cols-2 gap-4">
            <Button size="lg" asChild>
              <a href="/index">
                View Updated Home Page
              </a>
            </Button>
            <Button variant="outline" size="lg" asChild>
              <a href="/blog">
                View Enhanced Blog
              </a>
            </Button>
          </div>
          <div class="mt-4 text-sm text-muted-foreground">
            <p>All enhanced components are now ready for production use. They maintain full backward compatibility while providing improved design, accessibility, and user experience.</p>
          </div>
        </CardContent>
      </Card>
    </div>
  </div>
</BaseLayout>
