---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createATProtoClient } from "../lib/atproto";
import { getATProtoConfig } from "../config/atproto";
import ActivityFeed from "../components/ui/activity-feed";
import ProfileCard from "../components/ui/profile-card";
import {
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
} from "../components/ui/card";
import { Badge } from "../components/ui/badge";
import { Separator } from "../components/ui/separator";
import { Button } from "../components/ui/button";
import {
    Users,
    Clock,
    CalendarDays,
    ListFilter,
    GitFork,
    BookOpenText,
} from "lucide-react";

// Get AT Protocol configuration
const config = getATProtoConfig();

// Initialize AT Protocol client
const atClient = createATProtoClient(config);

// Fetch data at build time using unified approach
const { profile, recentActivity, repositoryStats, collections } =
    await atClient.getActivityData({
        includeBlogPosts: false,
        includeRepositoryStats: true,
        activityLimit: 20,
        blogPostLimit: 0,
        collectionsLimit: 5,
    });

// Use repository statistics if available, otherwise fallback to recent activity
const totalRecords = repositoryStats
    ? repositoryStats.totalRecords
    : recentActivity.length;
const recordsToday = repositoryStats
    ? repositoryStats.recordsToday
    : recentActivity.filter((record) => {
          const today = new Date();
          const recordDate = new Date(record.indexedAt);
          return recordDate.toDateString() === today.toDateString();
      }).length;

const recordsThisWeek = repositoryStats
    ? repositoryStats.recordsThisWeek
    : recentActivity.filter((record) => {
          const weekAgo = new Date();
          weekAgo.setDate(weekAgo.getDate() - 7);
          const recordDate = new Date(record.indexedAt);
          return recordDate >= weekAgo;
      }).length;

const activeCollectionsCount = repositoryStats
    ? repositoryStats.activeCollections
    : collections.filter((c) => c.records.length > 0).length;

const formatCollectionName = (collection: string): string => {
    if (collection.includes("feed.post")) return "Posts";
    if (collection.includes("feed.like")) return "Likes";
    if (collection.includes("repost")) return "Reposts";
    if (collection.includes("graph.follow")) return "Follows";
    if (collection.includes("blog.entry")) return "Blog Posts";
    if (collection.includes("actor.profile")) return "Profile Updates";
    return collection.split(".").pop() || "Other";
};
---

<BaseLayout
    title={`Activity - ${profile?.displayName || profile?.handle || "AT Home"}`}
    description="Recent activity from my AT Protocol repository"
    currentPage="activity"
    profile={profile}
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-4xl font-bold text-foreground mb-4">
                Activity Feed
            </h1>
            <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
                A comprehensive view of my activity across the AT Protocol
                ecosystem. This includes posts, likes, reposts, follows, and
                blog entries.
            </p>
        </div>

        <!-- Activity Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 mb-8">
            <Card class="p-6 text-center">
                <CardContent class="p-0">
                    <div class="text-3xl font-bold text-primary mb-2">
                        {totalRecords}
                    </div>
                    <div class="text-sm text-muted-foreground">
                        Total Records
                    </div>
                </CardContent>
            </Card>

            <Card class="p-6 text-center">
                <CardContent class="p-0">
                    <div
                        class="text-3xl font-bold text-green-600 dark:text-green-400 mb-2"
                    >
                        {recordsToday}
                    </div>
                    <div class="text-sm text-muted-foreground">Today</div>
                </CardContent>
            </Card>

            <Card class="p-6 text-center">
                <CardContent class="p-0">
                    <div
                        class="text-3xl font-bold text-purple-600 dark:text-purple-400 mb-2"
                    >
                        {recordsThisWeek}
                    </div>
                    <div class="text-sm text-muted-foreground">This Week</div>
                </CardContent>
            </Card>

            <Card class="p-6 text-center">
                <CardContent class="p-0">
                    <div
                        class="text-3xl font-bold text-orange-600 dark:text-orange-400 mb-2"
                    >
                        {activeCollectionsCount}
                    </div>
                    <div class="text-sm text-muted-foreground">
                        Active Collections
                    </div>
                </CardContent>
            </Card>
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Recent Activity Feed -->
            <div class="lg:col-span-2">
                <h2 class="text-2xl font-bold text-foreground mb-4">
                    Recent Activity
                </h2>
                <ActivityFeed
                    client:load
                    records={recentActivity}
                    title="All Recent Activity"
                    maxItems={20}
                    showViewAll={false}
                    emptyMessage="No recent activity"
                    emptySubMessage="Activity from your AT Protocol repository will appear here once you start creating records."
                />
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <!-- Profile Card -->
                {
                    profile && (
                        <div>
                            <h2 class="text-xl font-bold text-foreground mb-4">
                                Profile
                            </h2>
                            <ProfileCard
                                client:load
                                profile={profile}
                                compact={true}
                            />
                        </div>
                    )
                }

                <!-- Activity by Collection -->
                <Card>
                    <CardHeader>
                        <CardTitle class="text-lg flex items-center gap-2">
                            <ListFilter className="w-5 h-5" />
                            Activity by Type
                        </CardTitle>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-3">
                            {
                                repositoryStats
                                    ? Object.entries(
                                          repositoryStats.collectionCounts,
                                      ).map(([collection, count]) => (
                                          <div
                                              key={collection}
                                              class="flex items-center justify-between p-3 bg-muted rounded-lg"
                                          >
                                              <div class="flex items-center space-x-3">
                                                  <Badge
                                                      variant="outline"
                                                      className="text-sm"
                                                  >
                                                      {formatCollectionName(
                                                          collection,
                                                      )}
                                                  </Badge>
                                              </div>
                                              <span class="text-sm font-medium text-foreground">
                                                  {count}
                                              </span>
                                          </div>
                                      ))
                                    : collections.map((collection) => (
                                          <div
                                              key={collection.name}
                                              class="flex items-center justify-between p-3 bg-muted rounded-lg"
                                          >
                                              <div class="flex items-center space-x-3">
                                                  <Badge
                                                      variant="outline"
                                                      className="text-sm"
                                                  >
                                                      {formatCollectionName(
                                                          collection.name,
                                                      )}
                                                  </Badge>
                                              </div>
                                              <span class="text-sm font-medium text-foreground">
                                                  {collection.records.length}
                                              </span>
                                          </div>
                                      ))
                            }
                        </div>
                        {
                            repositoryStats && (
                                <div class="mt-4 pt-4 border-t border-border">
                                    <p class="text-xs text-muted-foreground">
                                        Statistics updated:{" "}
                                        {new Date(
                                            repositoryStats.lastUpdated,
                                        ).toLocaleString()}
                                    </p>
                                </div>
                            )
                        }
                    </CardContent>
                </Card>

                <!-- AT Protocol Collections Info -->
                <Card>
                    <CardHeader>
                        <CardTitle class="text-lg flex items-center gap-2">
                            <BookOpenText className="w-5 h-5" />
                            AT Protocol Collections
                        </CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground mb-4">
                            Your AT Protocol repository contains different types
                            of records organized into collections. Each
                            collection represents a different type of activity
                            or content.
                        </p>
                        <div class="space-y-2 text-sm text-muted-foreground">
                            <div class="flex items-center">
                                <Badge variant="secondary" className="mr-2"
                                    >📝</Badge
                                >
                                Posts & Content
                            </div>
                            <div class="flex items-center">
                                <Badge variant="secondary" className="mr-2"
                                    >❤️</Badge
                                >
                                Likes & Reactions
                            </div>
                            <div class="flex items-center">
                                <Badge variant="secondary" className="mr-2"
                                    >🔄</Badge
                                >
                                Shares & Reposts
                            </div>
                            <div class="flex items-center">
                                <Badge variant="secondary" className="mr-2"
                                    >👥</Badge
                                >
                                Social Connections
                            </div>
                        </div>
                    </CardContent>
                </Card>

                <!-- Repository Info -->
                <Card>
                    <CardHeader>
                        <CardTitle class="text-lg flex items-center gap-2">
                            <GitFork className="w-5 h-5" />
                            Your Repository
                        </CardTitle>
                    </CardHeader>
                    <CardContent>
                        {
                            profile && (
                                <div class="space-y-2 text-sm">
                                    <div class="flex items-center justify-between">
                                        <span class="text-muted-foreground">
                                            DID:
                                        </span>
                                        <code class="text-xs text-foreground bg-muted px-2 py-1 rounded">
                                            {profile.did.slice(0, 20)}...
                                        </code>
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-muted-foreground">
                                            Handle:
                                        </span>
                                        <span class="text-foreground font-medium">
                                            @{profile.handle}
                                        </span>
                                    </div>
                                </div>
                            )
                        }
                        <Separator class="my-4" />
                        <Button variant="outline" size="sm" asChild>
                            <a
                                href="https://atproto.com/guides/overview"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                Learn about AT Protocol →
                            </a>
                        </Button>
                    </CardContent>
                </Card>
            </div>
        </div>
    </div>
</BaseLayout>
