# AT Protocol Configuration
# Copy this file to .env and update with your actual credentials

# AT Protocol Service URL (usually https://bsky.social)
ATPROTO_SERVICE=https://bsky.social

# Your AT Protocol identifier (your handle)
ATPROTO_IDENTIFIER=your-handle.bsky.social

# Your AT Protocol handle (same as identifier for most users)
ATPROTO_HANDLE=your-handle.bsky.social

# Optional: App password for authenticated requests
# Create this in your Bluesky settings under "App passwords"
# ATPROTO_PASSWORD=your-app-password

# Site Configuration
# SITE_URL=https://your-domain.com
# SITE_TITLE=Your Name - Personal Portfolio
# SITE_DESCRIPTION=Personal portfolio and blog powered by the AT Protocol

# Build Configuration
# NODE_ENV=production
# DEBUG=false

# Optional: Analytics or tracking IDs
# ANALYTICS_ID=
# TRACKING_ID=

# Optional: Custom collections to monitor
# CUSTOM_COLLECTIONS=com.example.custom.record,com.another.collection

# Optional: Content limits
# MAX_BLOG_POSTS=50
# MAX_ACTIVITY_ITEMS=100
# REFRESH_INTERVAL=300000

# Optional: Feature flags
# ENABLE_DARK_MODE=true
# ENABLE_COMMENTS=false
# ENABLE_SEARCH=false
